name: CI
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
{% if "lint" in ci_targets %}
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - run: pip install ruff poetry && poetry install
      - run: ruff check .
{% endif %}
{% if "test" in ci_targets %}
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - run: pip install pytest poetry && poetry install
      - run: pytest tests/
{% endif %}
{% if "build" in ci_targets %}
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - run: pip install poetry && poetry install
      - run: poetry build
{% endif %}
